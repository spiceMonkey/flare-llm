flowchart TD
    h["Embedded token input<br/>h ∈ ℝ^H"]:::tok
    h --> WQ
    h --> WK
    h --> WV

    WQ["W_Q<br/>H × <b><i><font color='#0D47A1'>n_q</font></i></b>·d_head"]:::wt
    WK["W_K<br/>H × <b><i><font color='#AD1457'>n_kv</font></i></b>·d_head"]:::wt
    WV["W_V<br/>H × <b><i><font color='#AD1457'>n_kv</font></i></b>·d_head"]:::wt

    WQ --> Q["Q<br/><b><i><font color='#0D47A1'>n_q</font></i></b> × d_head"]:::q
    WK --> K["K<br/><b><i><font color='#AD1457'>n_kv</font></i></b> × d_head"]:::k
    WV --> V["V<br/><b><i><font color='#AD1457'>n_kv</font></i></b> × d_head"]:::v

    K -. "append" .-> KV
    V -. "append" .-> KV
    KV[("KV cache<br/>2·<b><i><font color='#AD1457'>n_kv</font></i></b>·d_head·b<br/>per token, per layer")]:::cache

    Q --> Attn
    KV ==> |"read all S+1<br/>(broadcast to <b><i><font color='#0D47A1'>n_q</font></i></b> heads per group)"| Attn
    Attn["Attention(Q, K, V)<br/>each <b><i><font color='#AD1457'>n_kv</font></i></b> K/V group serves <b><i><font color='#0D47A1'>n_q</font></i></b>/<b><i><font color='#AD1457'>n_kv</font></i></b> query heads"]:::attn

    Attn --> WO["W_O<br/><b><i><font color='#0D47A1'>n_q</font></i></b>·d_head × H"]:::wt
    WO --> o["Embedded token output<br/>o ∈ ℝ^H"]:::tok

    classDef tok fill:#B3D9FF,stroke:#1976D2,stroke-width:2px,color:#0D47A1
    classDef wt fill:#ECEFF1,stroke:#546E7A,color:#263238
    classDef q fill:#FFCDD2,stroke:#C62828,color:#B71C1C
    classDef k fill:#C8E6C9,stroke:#2E7D32,color:#1B5E20
    classDef v fill:#FFF9C4,stroke:#F57F17,color:#F57F17
    classDef cache fill:#F8BBD0,stroke:#AD1457,stroke-width:3px,color:#880E4F
    classDef attn fill:#FFE0B2,stroke:#E65100,stroke-width:2px,color:#BF360C
