flowchart LR
    subgraph full["Full attention (MHA / GQA / MLA): every query attends to all S past tokens"]
        direction TB
        fq["query at step S"]:::q
        fpast["past tokens<br/>(positions 1..S-1)"]:::tok
        fcache[("KV cache<br/>grows linearly with S<br/>(up to model max)")]:::cache
        fattn["attention<br/>O(S) per query<br/>full receptive field"]:::attn

        fpast -. "all stored" .-> fcache
        fq --> fattn
        fcache ==> |"read all S"| fattn
    end

    subgraph swa["Sliding-window attention: each query attends to last W tokens only"]
        direction TB
        sq["query at step S"]:::q
        spast["past tokens<br/>(only last <b><i><font color='#0D47A1'>W</font></i></b> visible)"]:::tok
        sevict["older tokens<br/>(positions ≤ S-W)<br/>evicted"]:::evict
        scache[("KV cache<br/>capped at <b><i><font color='#0D47A1'>W</font></i></b><br/>(rolling buffer)")]:::cache
        sattn["attention<br/>O(<b><i><font color='#0D47A1'>W</font></i></b>) per query<br/>local receptive field"]:::attn

        spast -. "kept" .-> scache
        sevict -. "dropped" .-> sevict
        sq --> sattn
        scache ==> |"read last W"| sattn
    end

