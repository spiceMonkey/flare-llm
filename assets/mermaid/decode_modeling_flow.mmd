%%{init: {'theme':'base', 'themeVariables': {'fontFamily':'monospace', 'fontSize':'24px'}}}%%
flowchart TD

    %% ── Inputs: four design pillars + workload point ──
    subgraph PILLARS ["Design pillars"]
      direction LR
      Model["<div style='min-width:130px'><b>Model</b><br/>L · H · attention variant<br/>MoE structure</div>"]
      HW["<div style='min-width:130px'><b>Hardware</b><br/>FLOPS · HBM · fabric<br/>INC capability</div>"]
      Part["<div style='min-width:130px'><b>Partition</b><br/>PP · TP · EP · SP</div>"]
      Stack["<div style='min-width:130px'><b>Serving stack</b><br/>algorithms · layout · overlaps<br/>host-side overheads</div>"]
    end

    WL["<div style='min-width:110px'><b>Workload point</b><br/>B · S</div>"]

    %% ── Validation + sharding ──
    Compose{"<div style='min-width:180px'><b>Cross-input validation + per-device sharding</b></div>"}
    Model --> Compose
    HW --> Compose
    Part --> Compose
    Stack --> Compose

    %% ── 4 cost branches ──
    Compose --> Memory
    Compose --> Compute
    Compose --> Comm
    Compose --> Stk
    WL -.-> Memory
    WL -.-> Compute
    WL -.-> Comm
    WL -.-> Stk

    Memory["<div style='min-width:190px'><b>Memory</b><br/>t_mem = Σ (T_θ + B·T_KV) / BW_eff</div>"]
    Compute["<div style='min-width:190px'><b>Compute</b><br/>t_compute = B · F_token / R_peak</div>"]
    Comm["<div style='min-width:190px'><b>Collective comm</b><br/>t_comm = Σ_axes n_X · t_X</div>"]
    Stk["<div style='min-width:190px'><b>Stack overheads</b><br/>t_stage,sw · t_serving · t_LM,hw · γ_pp</div>"]

    %% ── 3-stage assembly funnel ──
    Memory --> Local
    Compute --> Local
    Local{{"<div style='min-width:290px'><b>Roofline:</b> t_local = max(t_compute, t_mem)</div>"}}

    Local --> StageHW
    Comm --> StageHW
    StageHW{{"<div style='min-width:380px'><b>Compute–comm overlap (ρ):</b><br/>t_stage,hw = t_local + max(0, t_comm − ρ · t_local)</div>"}}

    StageHW --> Step
    Stk --> Step
    Step{{"<div style='min-width:500px'><b>HW–SW overlap (ρ_SW) + pipeline bubble (γ_pp):</b><br/>t_step,user = γ_pp · [t_stage,hw + max(0, t_stage,sw − ρ_SW · t_stage,hw)] + t_LM,hw + t_serving</div>"}}

    %% ── Outputs + bounds side-by-side ──
    Step --> Out
    Step -.-> Bounds

    Out["<div style='min-width:200px'><b>Outputs</b><br/>TPOT = t_step,user<br/>TTPS = DP · B / t_step,user</div>"]
    Bounds["<div style='min-width:200px'><b>Closed-form bounds</b><br/>B* · BW_link* · m_INC<br/>+ sensitivity table</div>"]

    %% ── Styling ──
    classDef pillar fill:#E3F2FD,stroke:#1565C0,stroke-width:2px,color:#0D47A1
    classDef workload fill:#FFF3E0,stroke:#EF6C00,stroke-width:2px,color:#E65100
    classDef gate fill:#F3E5F5,stroke:#7B1FA2,stroke-width:2.5px,color:#4A148C
    classDef branch fill:#FFFDE7,stroke:#F9A825,stroke-width:2px,color:#5D4037
    classDef assemble fill:#FCE4EC,stroke:#C2185B,stroke-width:2.5px,color:#880E4F
    classDef out fill:#E1F5FE,stroke:#01579B,stroke-width:2.5px,color:#01579B
    classDef sidebar fill:#F1F8E9,stroke:#558B2F,stroke-width:2px,stroke-dasharray: 5 3,color:#33691E

    class Model,HW,Part,Stack pillar
    class WL workload
    class Compose gate
    class Memory,Compute,Comm,Stk branch
    class Local,StageHW,Step assemble
    class Out out
    class Bounds sidebar

    style PILLARS fill:none,stroke:#ccc
