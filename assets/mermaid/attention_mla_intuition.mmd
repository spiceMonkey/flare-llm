flowchart LR
    subgraph mha["MHA: store full K, V"]
        direction TB
        mh["embedded token<br/>h"]:::tok
        mwkv["W_K, W_V<br/>full per-head"]:::wt
        mkv["K, V<br/>(<b><i><font color='#0D47A1'>n_q</font></i></b> heads wide)"]:::kv
        mcache[("KV cache<br/>2·<b><i><font color='#0D47A1'>n_q</font></i></b>·d_head·b<br/>per token, per layer")]:::cache
        matt["attention<br/>(direct K, V read)"]:::attn

        mh --> mwkv
        mwkv --> mkv
        mkv -. "append" .-> mcache
        mcache ==> matt
    end

    subgraph gqa["GQA: share K, V in groups"]
        direction TB
        gh["embedded token<br/>h"]:::tok
        gwkv["W_K, W_V<br/>narrower (per-group)"]:::wt
        gkv["K, V<br/>(<b><i><font color='#AD1457'>n_kv</font></i></b> groups, <b><i><font color='#AD1457'>n_kv</font></i></b> &lt; <b><i><font color='#0D47A1'>n_q</font></i></b>)"]:::kv
        gcache[("KV cache<br/>2·<b><i><font color='#AD1457'>n_kv</font></i></b>·d_head·b<br/>per token, per layer")]:::cache
        gatt["attention<br/>(broadcast K, V<br/>to <b><i><font color='#0D47A1'>n_q</font></i></b>/<b><i><font color='#AD1457'>n_kv</font></i></b> heads per group)"]:::attn

        gh --> gwkv
        gwkv --> gkv
        gkv -. "append" .-> gcache
        gcache ==> gatt
    end

    subgraph mla["MLA: factorize K, V into one shared latent"]
        direction TB
        lh["embedded token<br/>h"]:::tok
        ldown["W_DKV<br/>down-project"]:::wtdown
        lckv["c_KV<br/>single shared latent<br/>(no per-head)"]:::lat
        lcache[("KV cache<br/>(d_c + d_qk,rope)·b<br/>per token, per layer")]:::cache
        lup["W_UK, W_UV<br/>up-project on demand<br/>(or absorbed into Q/O)"]:::wtup
        latt["attention"]:::attn

        lh --> ldown
        ldown --> lckv
        lckv -. "append" .-> lcache
        lcache ==> lup
        lup --> latt
    end

    mha ~~~ gqa ~~~ mla

    classDef tok fill:#B3D9FF,stroke:#1976D2,stroke-width:2px,color:#0D47A1
    classDef wt fill:#ECEFF1,stroke:#546E7A,color:#263238
    classDef wtdown fill:#CFD8DC,stroke:#455A64,color:#263238
    classDef wtup fill:#E0E0E0,stroke:#616161,color:#212121
    classDef kv fill:#C8E6C9,stroke:#2E7D32,color:#1B5E20
    classDef lat fill:#D1C4E9,stroke:#5E35B1,color:#311B92
    classDef cache fill:#F8BBD0,stroke:#AD1457,stroke-width:3px,color:#880E4F
    classDef attn fill:#FFE0B2,stroke:#E65100,stroke-width:2px,color:#BF360C
