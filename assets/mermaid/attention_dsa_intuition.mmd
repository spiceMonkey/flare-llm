flowchart LR
    subgraph dense["MLA dense attention: every query attends to all S past tokens"]
        direction TB
        dq["query"]:::q
        dcache[("KV cache<br/>(MLA latent c_KV)<br/>S tokens")]:::cache
        dattn["attention<br/>over all S tokens<br/>O(S · n_q · d_qk)"]:::attn
        dout["output"]:::tok

        dq --> dattn
        dcache ==> |"read all S"| dattn
        dattn --> dout
    end

    subgraph dsa["DSA: lightweight indexer picks top-<b><i><font color='#0D47A1'>k</font></i></b>; attention only over selected"]
        direction TB
        sq["query"]:::q
        scache[("KV cache<br/>(MLA latent c_KV<br/>+ small indexer feature)<br/>S tokens")]:::cache
        sidx["indexer:<br/>score query<br/>vs each past token<br/>O(S · d_idx) — cheap"]:::idx
        ssel["top-<b><i><font color='#0D47A1'>k</font></i></b> selection<br/>(pick most relevant<br/>past tokens)"]:::sel
        sattn["attention<br/>over <b><i><font color='#0D47A1'>k</font></i></b> tokens only<br/>O(<b><i><font color='#0D47A1'>k</font></i></b> · n_q · d_qk)"]:::attn
        sout["output"]:::tok

        sq --> sidx
        scache ==> |"read all S<br/>for indexer"| sidx
        sidx --> ssel
        ssel --> sattn
        scache ==> |"read only<br/>selected k"| sattn
        sq --> sattn
        sattn --> sout
    end

