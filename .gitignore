# Ignore Python cache directories and local venv
**/__pycache__/
.llm_perf/

# Claude Code (not for public repo)
CLAUDE.md
.claude/

# Scratch / work-in-progress (local only)
scratch/
sandbox/

# Explaining docs — kept local until ready to publish
documentation/explaining/

# Notebooks — publish only quickstart + pareto_basic; keep the rest local
notebooks/*.ipynb
!notebooks/quickstart.ipynb
!notebooks/pareto_basic.ipynb

# HuggingFace raw configs — kept local (conversion inputs, not library data)
archives/

# mdBook build output (regenerated by deploy-book workflow)
book/build/

# Assets — publish only the PNGs referenced from README, public docs, and tutorial
assets/*.png
!assets/cluster_architecture.png
!assets/pareto_basic.png
!assets/pareto_basic_kernel_toggle.png
!assets/attention_dsa_intuition.png
!assets/attention_gqa.png
!assets/attention_head_sharing.png
!assets/attention_hybrid_intuition.png
!assets/attention_mha.png
!assets/attention_mla.png
!assets/attention_mla_intuition.png
!assets/attention_swa_intuition.png

# Mermaid sources + render helper — kept local
assets/mermaid/

# Scripts — publish only the documented HF conversion CLI
scripts/*.py
!scripts/convert_hf_model.py
