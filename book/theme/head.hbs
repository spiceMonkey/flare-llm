<!-- Open Graph / social-preview cards (LinkedIn, Slack, Twitter, ...).
     mdBook injects this file into <head> on every page. Keep the og:image an
     ABSOLUTE https URL — social crawlers do not resolve relative paths. The
     deploy workflow copies repo-root assets/ into the site, so
     /flare-llm/assets/logo.png is live on GitHub Pages. -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="FLARE" />
<meta property="og:title" content="FLARE — Fast LLM Analytical Roofline Explorer" />
<meta property="og:description" content="A lightweight, first-principles analytical framework for LLM inference performance — predict latency, throughput, and memory footprint on any cluster before you build or rent it." />
<meta property="og:url" content="https://spicemonkey.github.io/flare-llm/" />
<meta property="og:image" content="https://spicemonkey.github.io/flare-llm/assets/logo.png" />
<meta property="og:image:width" content="512" />
<meta property="og:image:height" content="512" />
<meta property="og:image:alt" content="FLARE logo" />
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content="FLARE — Fast LLM Analytical Roofline Explorer" />
<meta name="twitter:description" content="A lightweight, first-principles analytical framework for LLM inference performance — predict latency, throughput, and memory footprint on any cluster before you build or rent it." />
<meta name="twitter:image" content="https://spicemonkey.github.io/flare-llm/assets/logo.png" />
